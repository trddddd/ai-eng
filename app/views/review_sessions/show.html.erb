<% if @total > 0 %>
  <% content_for :filament_width do %><%= "width: #{(@position.to_f / @total * 100).round}%" %><% end %>
<% end %>

<div class="w-full">
  <% if @card %>
    <%= turbo_frame_tag "review_card" do %>
      <%= render "card_form", card: @card %>
    <% end %>
  <% else %>
    <%= turbo_frame_tag "review_card" do %>
      <%= render "empty_state" %>
    <% end %>
  <% end %>
</div>
