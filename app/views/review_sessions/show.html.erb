<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t("reviews.title") %></h1>

  <%= turbo_frame_tag "review_card" do %>
    <% if @card %>
      <%= render "card_form", card: @card %>
    <% else %>
      <%= render "empty_state" %>
    <% end %>
  <% end %>
</div>
