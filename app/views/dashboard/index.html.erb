<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">
      <%= t("dashboard.title") %>
    </h1>
    <%= button_to t("dashboard.logout"), logout_path, method: :delete,
          class: "py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 cursor-pointer" %>
  </div>

  <p class="text-gray-700">
    <%= t("dashboard.welcome", email: current_user.email) %>
  </p>

  <div class="mt-8">
    <%= link_to t("reviews.title"), review_path,
        class: "inline-block bg-indigo-600 text-white px-6 py-3 rounded-md hover:bg-indigo-700 text-lg" %>
  </div>
</div>
