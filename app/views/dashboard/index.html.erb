<div class="max-w-7xl mx-auto px-6 py-12">

  <header class="mb-12">
    <h1 class="font-body text-4xl md:text-5xl text-on-surface italic mb-2 leading-tight">
      <%= t("dashboard.welcome", email: current_user.email) %>
    </h1>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <div class="bg-surface-container-low rounded-xl p-6 flex items-center justify-between">
      <div>
        <p class="font-label text-xs text-on-surface-variant mb-1 uppercase tracking-widest"><%= t("dashboard.streak_label") %></p>
        <h3 class="font-headline text-2xl font-bold"><%= t("dashboard.streak_value", count: @progress.streak) %></h3>
      </div>
      <div class="w-12 h-12 bg-error-container/30 rounded-lg flex items-center justify-center">
        <span class="material-symbols-outlined text-error" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
      </div>
    </div>

    <div class="bg-surface-container-low rounded-xl p-6">
      <div class="flex items-center justify-between mb-3">
        <p class="font-label text-xs text-on-surface-variant uppercase tracking-widest">
          <%= t("dashboard.word_progress_label") %>
        </p>
        <div class="w-10 h-10 bg-primary-fixed/30 rounded-lg flex items-center justify-center">
          <span class="material-symbols-outlined text-primary text-lg">menu_book</span>
        </div>
      </div>

      <% if @progress.total_words_tracked.zero? %>
        <p class="font-body text-sm text-on-surface-variant mb-2">
          <%= t("dashboard.word_progress_empty") %>
        </p>
        <%= link_to t("dashboard.word_progress_review_cta"), review_path,
              class: "font-label text-sm font-semibold text-primary hover:underline" %>
      <% elsif @progress.words_zero_coverage == @progress.total_words_tracked %>
        <p class="font-body text-sm text-on-surface-variant mb-2">
          <%= t("dashboard.word_progress_encourage", count: @progress.total_words_tracked) %>
        </p>
      <% else %>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <h3 class="font-headline text-2xl font-bold"><%= @progress.words_zero_coverage %></h3>
            <p class="font-label text-xs text-on-surface-variant mt-0.5">
              <%= t("dashboard.word_progress_zero_label") %>
            </p>
          </div>
          <div>
            <h3 class="font-headline text-2xl font-bold text-primary"><%= @progress.words_partial_coverage %></h3>
            <p class="font-label text-xs text-on-surface-variant mt-0.5">
              <%= t("dashboard.word_progress_partial_label") %>
            </p>
          </div>
          <div>
            <h3 class="font-headline text-2xl font-bold text-tertiary"><%= @progress.words_full_coverage %></h3>
            <p class="font-label text-xs text-on-surface-variant mt-0.5">
              <%= t("dashboard.word_progress_full_label") %>
            </p>
          </div>
        </div>
      <% end %>
    </div>

    <% daily_pct = (@progress.daily_reviews.to_f / @progress.daily_goal).clamp(0, 1) %>
    <% circumference = 125.6 %>
    <% dashoffset = (circumference * (1 - daily_pct)).round(1) %>
    <div class="bg-surface-container-low rounded-xl p-6 flex items-center justify-between">
      <div>
        <p class="font-label text-xs text-on-surface-variant mb-1 uppercase tracking-widest"><%= t("dashboard.daily_goal_label") %></p>
        <h3 class="font-headline text-2xl font-bold"><%= @progress.daily_reviews %> / <%= @progress.daily_goal %></h3>
      </div>
      <div class="relative w-12 h-12">
        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 48 48">
          <circle class="text-surface-container-high" cx="24" cy="24" fill="transparent" r="20" stroke="currentColor" stroke-width="4"/>
          <circle class="text-tertiary" cx="24" cy="24" fill="transparent" r="20" stroke="currentColor"
            stroke-dasharray="<%= circumference %>"
            stroke-dashoffset="<%= dashoffset %>"
            stroke-width="4"
            stroke-linecap="round"/>
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="material-symbols-outlined text-tertiary text-sm" style="font-variation-settings: 'FILL' 1;">check</span>
        </div>
      </div>
    </div>

  </div>

  <div class="mt-8">
    <%= link_to t("reviews.title"), review_path,
        class: "font-label font-semibold text-primary hover:underline" %>
  </div>

</div>
