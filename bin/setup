#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args) # rubocop:disable Style/ArgumentsForwarding
  system(*args, exception: true) # rubocop:disable Style/ArgumentsForwarding
end

FileUtils.chdir APP_ROOT do # rubocop:disable Metrics/BlockLength
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  # puts "\n== Copying sample files =="
  # unless File.exist?("config/database.yml")
  #   FileUtils.cp "config/database.yml.sample", "config/database.yml"
  # end

  puts "\n== Checking PostgreSQL version =="
  pg_version = `docker compose exec postgres psql -U lingvize -d lingvize_development \
-t -c "SHOW server_version_num;" 2>/dev/null`.strip.to_i
  if pg_version < 180_000
    abort "ERROR: PostgreSQL 18+ required (uuidv7 support). Current server_version_num: #{pg_version}"
  end
  puts "PostgreSQL version OK (#{pg_version})"

  puts "\n== Preparing database =="
  if ARGV.include?("--reset")
    system! "bin/rails db:reset"
  elsif File.exist?(File.join(APP_ROOT, "db/dump/development.dump"))
    system! "bin/rails db:dump:restore"
    system! "bin/rails db:migrate"
  else
    puts "No dump found — running full setup (~30 min)..."
    puts "Downloading Tatoeba data files (required for sentence import)..."
    system! "bin/rails content_bootstrap:download_tatoeba"
    system! "bin/rails db:prepare"
    begin
      system! "bin/rails db:dump:create"
      puts "Dump saved to db/dump/development.dump. Next run will be fast."
    rescue RuntimeError => e
      warn "Warning: dump creation failed, next setup will run full seed again (#{e.message})"
    end
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    $stdout.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
